{% set image = image_items[0] %}
<figure
  class="single-inline-media single-inline-media--solo"
  data-news-gallery-group
  data-gallery-images="{{ image_items|json_encode(constant('JSON_UNESCAPED_UNICODE'))|e('html_attr') }}"
>
  <button
    type="button"
    class="single-inline-media__zoom"
    data-news-gallery-open
    data-gallery-index="0"
    aria-label="بزرگنمایی تصویر"
  >
    <img
      class="is-lazy"
      src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 720 480'%3E%3C/svg%3E"
      data-src="{{ image.url }}"
      data-ak-lazy-img
      alt="{{ image.alt|e('html_attr') }}"
      width="720"
      height="480"
      loading="lazy"
      decoding="async"
    />
    <span class="single-inline-media__shade" aria-hidden="true"></span>
    <span class="single-inline-media__icon" aria-hidden="true">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M15 3h6v6"/><path d="M9 21H3v-6"/><path d="M21 3l-7 7"/><path d="M3 21l7-7"/></svg>
    </span>
  </button>
</figure>
