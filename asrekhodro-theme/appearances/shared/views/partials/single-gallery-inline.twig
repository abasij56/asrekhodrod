<div
  class="single-gallery single-gallery--inline"
>
  <div
    class="single-gallery__grid single-gallery__grid--count-{{ image_items|length > 4 ? 'many' : image_items|length }}"
    data-news-gallery-group
    data-gallery-images="{{ image_items|json_encode(constant('JSON_UNESCAPED_UNICODE'))|e('html_attr') }}"
  >
    {% for image in image_items %}
      <button
        type="button"
        class="single-gallery__tile{% if loop.first and image_items|length > 2 %} single-gallery__tile--lead{% endif %}"
        data-news-gallery-open
        data-gallery-index="{{ loop.index0 }}"
        aria-label="نمایش تصویر {{ loop.index }} از {{ image_items|length }}"
      >
        <img
          src="{{ image.url }}"
          alt="{{ image.alt|e('html_attr') }}"
          width="640"
          height="427"
          loading="lazy"
          decoding="async"
        />
        <span class="single-gallery__shade" aria-hidden="true"></span>
        <span class="single-gallery__zoom" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M15 3h6v6"/><path d="M9 21H3v-6"/><path d="M21 3l-7 7"/><path d="M3 21l7-7"/></svg>
        </span>
        <span class="single-gallery__index">{{ loop.index|persian_digits }}</span>
      </button>
    {% endfor %}
  </div>
</div>
