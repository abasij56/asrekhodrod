{% for item in items %}
  <li class="main-nav__item{% if item.has_submenu %} has-submenu{% endif %}{% if item.show_date_filter %} has-date-filter{% endif %}">
    <div class="main-nav__item-head">
      <a href="{{ item.link }}" class="main-nav__link{{ item.current ? ' is-active' : '' }}">{{ item.title }}</a>
      {% if item.has_submenu %}
        <button
          type="button"
          class="main-nav__submenu-toggle"
          aria-expanded="false"
          aria-label="باز کردن زیرمنوی {{ item.title }}"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      {% endif %}
    </div>

    {% if item.has_submenu %}
      <div class="main-nav__submenu">
        {% if item.children|default([])|length > 0 %}
          <ul class="main-nav__sublist">
            {% for child in item.children %}
              <li>
                <a href="{{ child.link }}" class="main-nav__sublink{{ child.current ? ' is-active' : '' }}">{{ child.title }}</a>
              </li>
            {% endfor %}
          </ul>
        {% endif %}

        {% if item.show_date_filter %}
          {% include 'partials/main-nav-date-filter.twig' %}
        {% endif %}
      </div>
    {% endif %}
  </li>
{% endfor %}
