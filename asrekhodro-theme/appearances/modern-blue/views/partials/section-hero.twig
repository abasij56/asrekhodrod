{% import 'partials/macros.twig' as ak %}

{% if hero_main %}
{% if section_title|default('')|trim != '' %}
  {% include 'partials/section-head.twig' with { heading_id: 'hero-section-heading' } %}
{% endif %}
<section class="mb-hero" aria-labelledby="hero-heading">
  <div class="mb-hero__grid">
    <div class="mb-hero__copy">
      {% if hero_main.meta('_asrekhodro_over_title') %}
        <span class="mb-hero__eyebrow">
          <svg class="mb-hero__eyebrow-icon" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M13 2 3 14h8l-1 8 10-12h-8l1-8z"/></svg>
          {{ hero_main.meta('_asrekhodro_over_title') }}
        </span>
      {% else %}
        <span class="mb-hero__eyebrow">
          <svg class="mb-hero__eyebrow-icon" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M13 2 3 14h8l-1 8 10-12h-8l1-8z"/></svg>
          خبر ویژه روز
        </span>
      {% endif %}

      <h1 class="mb-hero__title" id="hero-heading">
        <a href="{{ hero_main.link }}">{{ hero_main.title }}</a>
      </h1>

      <p class="mb-hero__lead">
        {{ hero_main.post_excerpt|default(hero_main.post_content|striptags|slice(0, 220)) }}
      </p>

      <div class="mb-hero__cta">
        <a href="{{ hero_main.link }}" class="btn btn--primary">ادامه مطلب</a>
        {% if news_archive_url is defined and news_archive_url %}
          <a href="{{ news_archive_url }}" class="btn btn--outline">آرشیو اخبار</a>
        {% endif %}
      </div>
    </div>

    <div class="mb-hero__media">
      <a href="{{ hero_main.link }}" class="mb-hero__img-wrap" tabindex="-1" aria-hidden="true">
        {{ ak.post_image(hero_visual|default(hero_main), 1200, 800, 'eager') }}
      </a>
    </div>
  </div>

  {% if hero_side_posts|length %}
    <div class="mb-hero__stats" aria-label="اخبار مهم">
      {% for post in hero_side_posts|slice(0, 4) %}
        <article class="mb-hero__stat-card">
          <a href="{{ post.link }}" class="mb-hero__stat-link">
            <span class="mb-hero__stat-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6h16M4 12h10M4 18h14"/></svg>
            </span>
            {% if post.meta('_asrekhodro_over_title') %}
              <span class="mb-hero__stat-kicker">{{ post.meta('_asrekhodro_over_title') }}</span>
            {% endif %}
            <h3 class="mb-hero__stat-title">{{ post.title }}</h3>
            <time class="mb-hero__stat-meta" datetime="{{ post.date('Y-m-d') }}">{{ ak_post_date(post) }}</time>
          </a>
        </article>
      {% endfor %}
    </div>
  {% endif %}
</section>
{% endif %}
