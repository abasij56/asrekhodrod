{% import 'partials/macros.twig' as ak %}
{% if section_title is not defined %}{% set section_title = 'ویدئوهای عصر خودرو' %}{% endif %}

<section class="mb-videos"{% if section_title|trim != '' %} aria-labelledby="videos-heading"{% endif %}>
  {% if section_title|trim != '' %}
  <header class="mb-videos__head">
    <h2 id="videos-heading" class="mb-videos__title">{{ section_title }}</h2>
    <p class="mb-videos__sub">گزارش‌ها، تست‌ها و ویدئوهای ویژه از دنیای خودرو.</p>
    <a href="{{ fn('get_post_type_archive_link', 'ak_video') }}" class="mb-videos__archive">همه ویدئوها ←</a>
  </header>
  {% endif %}

  {% if videos|length > 0 %}
    <div class="mb-videos__panel">
      <div class="mb-videos__grid">
        {% for video in videos %}
          {% set vcat = video.terms('video_category')|first %}
          <article class="mb-videos__card{{ loop.first ? ' mb-videos__card--lead' : '' }}">
            <a href="{{ video.link }}" class="mb-videos__card-link">
              <div class="mb-videos__media">
                {% if video.thumbnail %}
                  <img src="{{ video.thumbnail.src(loop.first ? 'large' : 'medium') }}" alt="{{ video.title }}" loading="lazy" decoding="async" />
                {% else %}
                  {{ ak.post_image(video, loop.first ? 960 : 640, loop.first ? 540 : 360) }}
                {% endif %}
                <span class="mb-videos__play" aria-hidden="true"></span>
              </div>
              <div class="mb-videos__body">
                {% if vcat %}
                  <span class="mb-videos__tag">{{ vcat.name }}</span>
                {% endif %}
                <h3 class="mb-videos__card-title">{{ video.title }}</h3>
                <time class="mb-videos__date" datetime="{{ video.date('Y-m-d') }}">{{ ak_post_date(video) }}</time>
              </div>
            </a>
          </article>
        {% endfor %}
      </div>
    </div>
  {% else %}
    <p class="mb-videos__empty">ویدئویی ثبت نشده است.</p>
  {% endif %}
</section>
