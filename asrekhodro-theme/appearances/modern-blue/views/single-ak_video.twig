{% extends 'base.twig' %}
{% import 'partials/macros.twig' as ak %}

{% block before_main %}
  {% include 'partials/layout-zone.twig' with { zone: 'before_main' } %}
{% endblock %}

{% block content %}
<div class="container single-shell single-shell--video mb-video-single-page">
  <div class="single-grid">
    <main class="single-main" id="main-content">
      <article class="mb-video-single video-single">
        <header class="mb-video-single__head video-single__head">
          {% set vcat = post.terms('video_category')|first %}
          {% if vcat %}
            <a class="mb-video-single__category video-single__category" href="{{ vcat.link }}">{{ vcat.name }}</a>
          {% endif %}
          <h1 class="mb-video-single__title video-single__title">{{ post.title }}</h1>
          <time class="mb-video-single__date video-single__date" datetime="{{ post.date('Y-m-d') }}">{{ ak_post_date(post) }}</time>
        </header>

        <div class="mb-video-single__player video-single__player">
          {% if video_player_html %}
            {{ video_player_html|raw }}
          {% elseif video_url %}
            <div class="ak-video-player mb-video-single__native-player">
              <video controls preload="metadata" playsinline src="{{ video_url }}"></video>
            </div>
          {% endif %}
        </div>

        {% if video_body_html %}
          <div class="mb-video-single__body video-single__body body-text">
            {{ video_body_html|raw }}
          </div>
        {% endif %}

        {% if post.post_excerpt %}
          <p class="mb-video-single__excerpt video-single__excerpt">{{ post.post_excerpt|striptags }}</p>
        {% endif %}

        <p class="mb-video-single__back video-single__back">
          <a href="{{ fn('get_post_type_archive_link', 'ak_video') }}">← همه ویدئوها</a>
        </p>
      </article>

      {% if related_videos|length > 0 %}
        <section class="mb-video-single__related video-single__related" aria-labelledby="related-videos-heading">
          <header class="mb-video-single__related-head">
            <h2 id="related-videos-heading" class="mb-video-single__related-title">ویدئوهای مرتبط</h2>
            <a href="{{ fn('get_post_type_archive_link', 'ak_video') }}" class="mb-video-single__related-archive">همه ویدئوها ←</a>
          </header>
          <div class="mb-video-single__related-grid">
            {% for video in related_videos %}
              {% set rvcat = video.terms('video_category')|first %}
              <article class="mb-video-single__card">
                <a href="{{ video.link }}" class="mb-video-single__card-link">
                  <div class="mb-video-single__card-media">
                    {% if video.thumbnail %}
                      <img src="{{ video.thumbnail.src('medium') }}" alt="{{ video.title }}" loading="lazy" decoding="async" />
                    {% else %}
                      {{ ak.post_image(video, 640, 360) }}
                    {% endif %}
                    <span class="mb-video-single__card-play" aria-hidden="true"></span>
                  </div>
                  <div class="mb-video-single__card-body">
                    {% if rvcat %}
                      <span class="mb-video-single__card-tag">{{ rvcat.name }}</span>
                    {% endif %}
                    <h3 class="mb-video-single__card-title">{{ video.title }}</h3>
                    <time class="mb-video-single__card-date" datetime="{{ video.date('Y-m-d') }}">{{ ak_post_date(video) }}</time>
                  </div>
                </a>
              </article>
            {% endfor %}
          </div>
        </section>
      {% endif %}
    </main>
    {% include 'partials/layout-zone.twig' with { zone: 'sidebar' } %}
  </div>
</div>
{% endblock %}
