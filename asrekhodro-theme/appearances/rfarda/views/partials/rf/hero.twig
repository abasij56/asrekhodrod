{% import 'partials/macros.twig' as ak %}

{% if hero_main %}
<section class="rf-hero rfarda-hero" aria-labelledby="rf-hero-heading">
  {% include 'partials/rfarda/column-head.twig' with { title: 'خبر اول', id: 'rf-hero-heading', variant: 'lead' } %}

  <div class="rfarda-hero__lead-wrap">
    <a href="{{ hero_main.link }}" class="rf-lead-story rfarda-lead-story">
      <div class="rf-lead-story__image rfarda-lead-story__image">
        {{ ak.post_image(hero_visual|default(hero_main), 900, 506, 'eager') }}
        <span class="rf-lead-story__badge rfarda-live-badge">زنده</span>
      </div>
      <div class="rf-lead-story__body">
        {% set lead_cat = hero_main.categories|first %}
        {% if lead_cat %}
          <div class="rf-lead-story__category">{{ lead_cat.name }}</div>
        {% elseif hero_main.meta('_asrekhodro_over_title') %}
          <div class="rf-lead-story__category">{{ hero_main.meta('_asrekhodro_over_title') }}</div>
        {% endif %}
        <h3 class="rf-lead-story__title">{{ hero_main.title }}</h3>
        <p class="rf-lead-story__excerpt">{{ ak.list_excerpt(hero_main) }}</p>
        <div class="rf-lead-story__meta">
          <span>{{ rf_site_name|default('عصر خودرو') }}</span>
          <time datetime="{{ hero_main.date('Y-m-d') }}">{{ ak_post_date(hero_main) }}</time>
        </div>
      </div>
    </a>

    {% if hero_side_posts|length > 0 %}
      <div class="rfarda-hero__mini-cards">
        {% for post in hero_side_posts|slice(0, 2) %}
          <a href="{{ post.link }}" class="rfarda-mini-card">
            <div class="rfarda-mini-card__image">
              {{ ak.post_image(post, 160, 100) }}
            </div>
            <h3 class="rfarda-mini-card__title">{{ post.title }}</h3>
          </a>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>
{% endif %}
