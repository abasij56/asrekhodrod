{% import 'partials/macros.twig' as ak %}

{% if posts|length > 0 %}
<section class="rf-section rfarda-section{% if layout|default('') == 'row' %} rfarda-section--row{% endif %}" aria-labelledby="{{ section_id }}-heading">
  {% if more_url %}
    <div class="section-head rfarda-news-section__head">
      <h2 id="{{ section_id }}-heading">{{ title }}</h2>
      <a href="{{ more_url }}">{{ more_label|default('همه خبرها ←') }}</a>
    </div>
  {% else %}
    <div class="rf-section__header rfarda-section__header">
      <h2 id="{{ section_id }}-heading" class="rf-section__title rfarda-section__title">
        <span class="rfarda-chevron" aria-hidden="true">›</span>
        {{ title }}
      </h2>
    </div>
  {% endif %}
  <div class="rf-news-grid{% if layout|default('') == 'row' %} rfarda-news-row{% endif %}">
    {% for post in posts %}
      <a href="{{ post.link }}" class="rf-news-card rfarda-news-card">
        <div class="rf-news-card__image rfarda-news-card__image">
          {{ ak.post_image(post, layout|default('') == 'row' ? 400 : 200, layout|default('') == 'row' ? 225 : 150) }}
        </div>
        <div class="rf-news-card__body">
          {% set cat = post.categories|first %}
          {% if cat %}
            <div class="rf-news-card__category">{{ cat.name }}</div>
          {% endif %}
          <h3 class="rf-news-card__title">{{ post.title }}</h3>
          <time class="rf-news-card__date" datetime="{{ post.date('Y-m-d') }}">{{ ak_post_date(post) }}</time>
        </div>
      </a>
    {% endfor %}
  </div>
</section>
{% endif %}
