<section class="rf-section rfarda-section" aria-labelledby="rf-beyond-heading">
  <div class="rf-section__header rfarda-section__header">
    <h2 id="rf-beyond-heading" class="rf-section__title rfarda-section__title">
      <span class="rfarda-chevron" aria-hidden="true">›</span>
      دسته‌بندی‌ها
    </h2>
  </div>
  <div class="rf-category-blocks rfarda-category-blocks">
    {% for block in rf_category_blocks %}
      <div class="rf-category-block rfarda-category-block">
        <div class="rf-category-block__head">
          <h3>{{ block.title }}</h3>
          <a href="{{ block.url }}" class="rf-section__more">بیشتر</a>
        </div>
        <ul class="rf-category-block__list">
          {% for post in block.posts %}
            <li>
              <a href="{{ post.link }}">
                {% if block.numbered|default(false) %}
                  <span class="rfarda-category-block__num">{{ loop.index }}</span>
                {% endif %}
                <span class="rfarda-category-block__text">{{ post.title }}</span>
                <div class="date">{{ ak_post_date(post) }}</div>
              </a>
            </li>
          {% endfor %}
        </ul>
      </div>
    {% endfor %}
  </div>
</section>
