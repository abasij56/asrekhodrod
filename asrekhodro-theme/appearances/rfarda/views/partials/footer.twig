<footer class="site-footer site-footer--rfarda rfarda-footer">
  <div class="container">
    <div class="rfarda-footer__grid">
      <div class="rfarda-footer__col">
        <div class="rfarda-footer__logo-wrap">
          {% include 'partials/site-logo.twig' with { class: 'rfarda-footer__logo', variant: 'footer' } %}
        </div>
        {% if main_nav and main_nav.items|length > 0 %}
          <ul class="rfarda-footer__links">
            {% for item in main_nav.items|slice(0, 4) %}
              <li><a href="{{ item.link }}">{{ item.title }}</a></li>
            {% endfor %}
          </ul>
        {% else %}
          <ul class="rfarda-footer__links">
            <li><a href="{{ site.url }}">صفحه اصلی</a></li>
            <li><a href="#">اخبار خودرو</a></li>
            <li><a href="#">بازار خودرو</a></li>
            <li><a href="#">ویدئو</a></li>
          </ul>
        {% endif %}
      </div>

      <div class="rfarda-footer__col">
        <h4 class="rfarda-footer__heading">درباره</h4>
        {% if footer_nav_about %}
          <ul class="rfarda-footer__links">
            {% for item in footer_nav_about.items %}
              <li><a href="{{ item.link }}">{{ item.title }}</a></li>
            {% endfor %}
          </ul>
        {% else %}
          <ul class="rfarda-footer__links">
            <li><a href="#">درباره ما</a></li>
            <li><a href="#">تماس با ما</a></li>
            <li><a href="#">تبلیغات</a></li>
          </ul>
        {% endif %}
      </div>

      <div class="rfarda-footer__col rfarda-footer__col--join">
        <h4 class="rfarda-footer__heading">به ما بپیوندید</h4>
        <div class="rfarda-footer__socials" aria-label="شبکه‌های اجتماعی">
          {% if options.social_instagram %}
            <a href="{{ options.social_instagram }}" class="rfarda-footer__social-btn" aria-label="اینستاگرام" rel="noopener noreferrer">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
            </a>
          {% endif %}
          {% if options.social_telegram %}
            <a href="{{ options.social_telegram }}" class="rfarda-footer__social-btn" aria-label="تلگرام" rel="noopener noreferrer">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
            </a>
          {% endif %}
          {% if options.social_youtube %}
            <a href="{{ options.social_youtube }}" class="rfarda-footer__social-btn" aria-label="یوتیوب" rel="noopener noreferrer">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            </a>
          {% endif %}
          <a href="{{ site.link }}/feed/" class="rfarda-footer__social-btn" aria-label="خوراک RSS">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20 5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/></svg>
          </a>
        </div>
      </div>
    </div>

    <p class="rfarda-footer__copyright">
      © {{ "now"|date("Y") }} تمام حقوق این وب‌سایت، بر اساس مقررات کپی‌رایت، برای {{ site.name }} محفوظ است.
    </p>
  </div>
</footer>
