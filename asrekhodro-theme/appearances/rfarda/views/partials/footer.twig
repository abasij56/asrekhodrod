<footer class="site-footer site-footer--rfarda rfarda-footer">
  <div class="container">
    <div class="rfarda-footer__grid">
      <div class="rfarda-footer__col">
        <div class="rfarda-footer__logo-wrap">
          {% include 'partials/site-logo.twig' with { class: 'rfarda-footer__logo', variant: 'footer' } %}
        </div>
        {% if main_nav and main_nav.items|length > 0 %}
          <ul class="rfarda-footer__links">
            {% for item in main_nav.items|slice(0, 4) %}
              <li><a href="{{ item.link }}">{{ item.title }}</a></li>
            {% endfor %}
          </ul>
        {% else %}
          <ul class="rfarda-footer__links">
            <li><a href="{{ site.url }}">صفحه اصلی</a></li>
            <li><a href="#">اخبار خودرو</a></li>
            <li><a href="#">بازار خودرو</a></li>
            <li><a href="#">ویدئو</a></li>
          </ul>
        {% endif %}
      </div>

      <div class="rfarda-footer__col">
        <h4 class="rfarda-footer__heading">درباره</h4>
        {% if footer_nav_about %}
          <ul class="rfarda-footer__links">
            {% for item in footer_nav_about.items %}
              <li><a href="{{ item.link }}">{{ item.title }}</a></li>
            {% endfor %}
          </ul>
        {% else %}
          <ul class="rfarda-footer__links">
            <li><a href="#">درباره ما</a></li>
            <li><a href="#">تماس با ما</a></li>
            <li><a href="#">تبلیغات</a></li>
          </ul>
        {% endif %}
      </div>

      <div class="rfarda-footer__col rfarda-footer__col--join">
        <h4 class="rfarda-footer__heading">به ما بپیوندید</h4>
        <div class="rfarda-footer__socials" aria-label="شبکه‌های اجتماعی">
          {% for item in footer_social_links|default([]) %}
            <a href="{{ item.url }}" class="rfarda-footer__social-btn" aria-label="{{ item.label }}" rel="noopener noreferrer">{{ item.svg|raw }}</a>
          {% endfor %}
          <a href="{{ site.link }}/feed/" class="rfarda-footer__social-btn" aria-label="خوراک RSS">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20 5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/></svg>
          </a>
        </div>
      </div>
    </div>

    <p class="rfarda-footer__copyright">
      © {{ "now"|date("Y") }} تمام حقوق این وب‌سایت، بر اساس مقررات کپی‌رایت، برای {{ site.name }} محفوظ است.
    </p>
  </div>
</footer>
