    </div>

    <nav class="main-nav rfarda-nav" id="main-nav" aria-label="منوی اصلی">
      <ul class="main-nav__list rfarda-nav__list">
        {% include 'partials/main-nav-items.twig' with { items: main_nav_items|default([]) } %}
