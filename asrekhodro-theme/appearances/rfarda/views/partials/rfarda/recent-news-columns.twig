{% if rf_recent_posts|length > 0 %}
<section class="news-list-section rfarda-recent-news" aria-labelledby="rfarda-recent-news-heading">
  <div class="section-head rfarda-news-section__head">
    <h2 id="rfarda-recent-news-heading">{{ rf_recent_title|default('آخرین خبرها') }}</h2>
    {% if news_archive_url %}
      <a href="{{ news_archive_url }}">{{ rf_recent_more_label|default('همه خبرها ←') }}</a>
    {% endif %}
  </div>

  <div class="rfarda-recent-news__grid">
    {% for column in rf_recent_posts|batch(10) %}
      <ul class="news-list rfarda-recent-news__col" role="list">
        {% for post in column %}
          {% include 'partials/news-list-item.twig' with { post: post } %}
        {% endfor %}
      </ul>
    {% endfor %}
  </div>
</section>
{% endif %}
