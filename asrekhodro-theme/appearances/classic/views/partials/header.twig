<header class="site-header">
  <div class="container">
    <div class="site-header__top">
      <div class="site-header__brand">
        {% include 'partials/site-logo.twig' with { variant: 'header' } %}
        <button class="nav-toggle" id="nav-toggle" type="button" aria-label="باز کردن منو" aria-expanded="false" aria-controls="main-nav">
          <span></span><span></span><span></span>
        </button>
      </div>

      <div class="site-header__aside">
        <div class="site-header__date">
          <span>امروز:</span>
          <time id="current-date" datetime="{{ today_iso }}">{{ today_persian }}</time>
        </div>

        <div class="site-header__lang">
          {{ function('do_shortcode', '[abi_language_switcher]') }}
        </div>

        <div class="site-header__search-wrap" data-ak-search-wrap>
          <form class="site-header__search" role="search" data-ak-search>
            <input
              type="search"
              name="s"
              placeholder="جستجو در اخبار، خودروها و ویدئوها..."
              aria-label="عبارت جستجو"
              autocomplete="off"
              aria-controls="ak-search-dropdown"
              aria-expanded="false"
              aria-autocomplete="list"
            />
            <button type="button" class="site-header__search-trigger" data-ak-search-trigger aria-label="جستجو">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            </button>
          </form>
          <div class="ak-search-dropdown" id="ak-search-dropdown" data-ak-search-dropdown hidden role="listbox" aria-label="پیشنهادهای جستجو"></div>
        </div>
      </div>
    </div>

    <nav class="main-nav" id="main-nav" aria-label="منوی اصلی">
      <ul class="main-nav__list">
        {% include 'partials/main-nav-items.twig' with { items: main_nav_items|default([]) } %}
      </ul>
      {% if google_follow_url|default('') %}
        <a
          href="{{ google_follow_url }}"
          class="main-nav__google-follow"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg class="main-nav__google-follow-icon" width="16" height="16" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
          </svg>
          <span>ما را در گوگل دنبال کنید</span>
        </a>
      {% endif %}
    </nav>
  </div>
</header>
