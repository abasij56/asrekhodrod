{% if video_url %}
<div class="video-cinema-stage__frame">
  <div class="video-cinema-stage__frame-glow" aria-hidden="true"></div>
  <div class="video-cinema-stage__frame-inner">
    <div class="video-cinema-stage__native{% if video_poster_url %} video-cinema-stage__native--poster{% endif %}" data-video-cinema-native>
      {% if video_poster_url %}
        <button type="button" class="video-cinema-stage__poster" data-video-cinema-play aria-label="پخش ویدیو">
          <img
            class="video-cinema-stage__poster-image"
            src="{{ video_poster_url }}"
            alt="{{ video_poster_alt|default('')|e('html_attr') }}"
            width="1280"
            height="720"
            loading="eager"
            decoding="async"
          />
          <span class="video-cinema-stage__poster-shade" aria-hidden="true"></span>
          {% include 'partials/video-card-play.twig' %}
        </button>
      {% endif %}
      <div class="ak-video-player">
        <video
          controls
          preload="metadata"
          playsinline
          src="{{ video_url }}"
          {% if video_poster_url %}poster="{{ video_poster_url }}"{% endif %}
        ></video>
      </div>
    </div>
  </div>
</div>
{% elseif video_embed_html %}
<div class="video-cinema-stage__frame">
  <div class="video-cinema-stage__frame-glow" aria-hidden="true"></div>
  <div class="video-cinema-stage__frame-inner">
    <div class="video-cinema-stage__embed">
      {{ video_embed_html|raw }}
    </div>
  </div>
</div>
{% endif %}
