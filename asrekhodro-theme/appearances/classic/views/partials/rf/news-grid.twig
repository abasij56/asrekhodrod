{% import 'partials/macros.twig' as ak %}

{% if posts|length > 0 %}
<section class="rf-section" aria-labelledby="{{ section_id }}-heading">
  <div class="rf-section__header">
    <h2 id="{{ section_id }}-heading" class="rf-section__title">{{ title }}</h2>
    {% if more_url %}
      <a href="{{ more_url }}" class="rf-section__more">مشاهده همه ←</a>
    {% endif %}
  </div>
  <div class="rf-news-grid">
    {% for post in posts %}
      <a href="{{ post.link }}" class="rf-news-card">
        <div class="rf-news-card__image">
          {{ ak.post_image(post, 200, 150) }}
        </div>
        <div class="rf-news-card__body">
          {% set cat = post.categories|first %}
          {% if cat %}
            <div class="rf-news-card__category">{{ cat.name }}</div>
          {% endif %}
          <h3 class="rf-news-card__title">{{ post.title }}</h3>
          <time class="rf-news-card__date" datetime="{{ post.date('Y-m-d') }}">{{ ak_post_date(post) }}</time>
        </div>
      </a>
    {% endfor %}
  </div>
</section>
{% endif %}
