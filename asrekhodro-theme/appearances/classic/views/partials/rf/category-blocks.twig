<section class="rf-section" aria-labelledby="rf-beyond-heading">
  <div class="rf-section__header">
    <h2 id="rf-beyond-heading" class="rf-section__title">فراتر از خبر</h2>
  </div>
  <div class="rf-category-blocks">
    {% for block in rf_category_blocks %}
      <div class="rf-category-block">
        <div class="rf-category-block__head">
          <h3>{{ block.title }}</h3>
          <a href="{{ block.url }}" class="rf-section__more">بیشتر</a>
        </div>
        <ul class="rf-category-block__list">
          {% for post in block.posts %}
            <li>
              <a href="{{ post.link }}">
                {% if block.numbered|default(false) %}{{ loop.index }}. {% endif %}{{ post.title }}
                <div class="date">{{ ak_post_date(post) }}</div>
              </a>
            </li>
          {% endfor %}
        </ul>
      </div>
    {% endfor %}
  </div>
</section>
