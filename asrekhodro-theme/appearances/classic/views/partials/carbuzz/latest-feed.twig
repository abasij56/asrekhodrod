{% import 'partials/macros.twig' as ak %}

{% if cb_latest|length > 0 %}
<section class="cb-section cb-latest" aria-labelledby="cb-latest-heading">
  <header class="cb-section__head">
    <h2 id="cb-latest-heading" class="cb-section__title">آخرین مطالب</h2>
    <a href="{{ cb_archive_url }}" class="cb-section__more">مشاهده همه</a>
  </header>
  <div class="cb-latest__feed">
    {% for post in cb_latest %}
      <article class="cb-latest-item">
        <a href="{{ post.link }}">
          <div class="cb-latest-item__media">{{ ak.post_image(post, 280, 175) }}</div>
          <div class="cb-latest-item__body">
            {% set cat = post.categories|first %}
            {% if cat %}<span class="cb-latest-item__tag">{{ cat.name }}</span>{% endif %}
            <h3>{{ post.title }}</h3>
            <p>{{ ak.list_excerpt(post) }}</p>
            <div class="cb-latest-item__meta">
              {% if post.meta('_asrekhodro_author') %}
                <span>{{ post.meta('_asrekhodro_author') }}</span>
              {% endif %}
              <time datetime="{{ post.date('Y-m-d') }}">{{ ak_post_date(post) }}</time>
            </div>
          </div>
        </a>
      </article>
    {% endfor %}
  </div>
  <footer class="cb-latest__footer">
    <a href="{{ cb_archive_url }}" class="cb-btn cb-btn--outline">مشاهده مطالب بیشتر</a>
  </footer>
</section>
{% endif %}
