<div class="news-gallery" data-news-gallery hidden>
  <button type="button" class="news-gallery__close" data-news-gallery-close aria-label="بستن">&times;</button>
  <button type="button" class="news-gallery__nav news-gallery__nav--next" data-news-gallery-next aria-label="تصویر بعدی">
    <svg class="news-gallery__nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>
  <button type="button" class="news-gallery__nav news-gallery__nav--prev" data-news-gallery-prev aria-label="تصویر قبلی">
    <svg class="news-gallery__nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>
  <figure class="news-gallery__figure">
    <img class="news-gallery__image" src="" alt="" />
  </figure>
  <div class="news-gallery__counter" aria-live="polite">
    <span data-news-gallery-current>1</span>
    <span aria-hidden="true">/</span>
    <span data-news-gallery-total>1</span>
  </div>
</div>
