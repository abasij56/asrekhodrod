<section class="rail-widget rail-widget--kiosk rail-widget--videos" aria-labelledby="sidebar-videos-heading">
  <div class="rail-widget__head">
    <h2 id="sidebar-videos-heading" class="rail-widget__title">{{ section_title|default('ویدیوها') }}</h2>
    {% if archive_url|default('') %}
      <a href="{{ archive_url }}" class="rail-widget__archive">آرشیو</a>
    {% endif %}
  </div>
  <div class="kiosk-carousel" data-ak-kiosk>
    <div class="kiosk-carousel__viewport">
      <ul class="kiosk-carousel__track">
        {% for item in items %}
          <li class="kiosk-carousel__slide">
            <a href="{{ item.link }}">
              <span class="kiosk-carousel__cover">
                <img src="{{ item.image }}" alt="{{ item.alt }}" width="220" height="305" loading="lazy" decoding="async" />
                {% include 'partials/video-card-play.twig' %}
              </span>
            </a>
          </li>
        {% endfor %}
      </ul>
    </div>
    <div class="kiosk-carousel__controls" hidden>
      <button type="button" class="kiosk-carousel__btn kiosk-carousel__btn--prev" data-kiosk-prev aria-label="قبلی">
        <svg class="kiosk-carousel__btn-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <div class="kiosk-carousel__dots" data-kiosk-dots></div>
      <button type="button" class="kiosk-carousel__btn kiosk-carousel__btn--next" data-kiosk-next aria-label="بعدی">
        <svg class="kiosk-carousel__btn-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </div>
</section>
