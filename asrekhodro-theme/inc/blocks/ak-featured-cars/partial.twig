{% set fc_title = featured_cars_title|default('ماشین‌های منتخب') %}

<section class="reviews featured-cars"{% if fc_title|trim != '' %} aria-labelledby="featured-cars-heading"{% endif %}>
  {% include 'partials/section-head.twig' with {
    section_title: fc_title,
    heading_id: 'featured-cars-heading',
    section_link_url: featured_cars_link_url|default(''),
    section_link_label: featured_cars_link_label|default('همه مدل‌ها ←')
  } %}

  {% if featured_cars_has_items %}
    <div class="review-grid">
      {% for car in featured_cars %}
        <article class="review-card review-card--car">
          <a href="{{ car.url }}">
            <div class="review-card__media">
              {% if car.image.url %}
                <img src="{{ car.image.url }}" width="{{ car.image.width|default(600) }}" height="{{ car.image.height|default(375) }}" alt="{{ car.image.alt|default(car.title) }}" loading="lazy" decoding="async" />
              {% endif %}
              {% if car.brand.logo.url %}
                <span class="review-card__brand review-card__brand--logo"><img src="{{ car.brand.logo.url }}" alt="{{ car.brand.name }}" loading="lazy" decoding="async" /></span>
              {% elseif car.brand.abbr %}
                <span class="review-card__brand" aria-hidden="true">{{ car.brand.abbr }}</span>
              {% endif %}
              {% if car.rates|length > 0 %}
                <div class="review-card__rates" aria-hidden="true">
                  {% for rate in car.rates %}
                    <div class="review-card__rate">
                      <span class="review-card__rate-title">{{ rate.title }}</span>
                      <span class="review-card__rate-bar"><span style="width:{{ rate.bar_width }}%"></span></span>
                      <span class="review-card__rate-value">{{ rate.rate_label }}</span>
                    </div>
                  {% endfor %}
                </div>
              {% endif %}
            </div>
            <div class="review-card__body">
              <h3>{{ car.title }}</h3>
              {% if car.specs|length > 0 %}
                <div class="review-card__specs">
                  {% for spec in car.specs %}
                    <div class="review-card__spec">
                      {% if spec.label %}
                        <span class="review-card__spec-title">{{ spec.label }}</span>
                      {% endif %}
                      {% if spec.icon_svg %}
                        <span class="review-card__spec-icon" aria-hidden="true">{{ spec.icon_svg|raw }}</span>
                      {% elseif spec.icon_sprite and spec.icon_url %}
                        <span class="review-card__spec-icon" aria-hidden="true"><svg class="ak-icon"><use href="{{ spec.icon_url }}"></use></svg></span>
                      {% elseif spec.icon_url %}
                        <span class="review-card__spec-icon" aria-hidden="true"><span class="review-card__spec-mask" style="--ak-mask:url('{{ spec.icon_url }}')"></span></span>
                      {% endif %}
                      <span class="review-card__spec-label">{{ spec.text }}</span>
                    </div>
                  {% endfor %}
                </div>
              {% endif %}
              <span class="review-card__cta">
                مشاهده خودرو
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M19 12H5"/><path d="M11 6l-6 6 6 6"/></svg>
              </span>
            </div>
          </a>
        </article>
      {% endfor %}
    </div>
  {% else %}
    <p class="featured-cars__empty">هنوز خودرویی برای نمایش انتخاب نشده است.</p>
  {% endif %}
</section>
